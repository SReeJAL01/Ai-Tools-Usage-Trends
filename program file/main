# Install libraries

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Upload CSV

df = pd.read_csv("/content/GenAI Tools.csv")
df.head()

# Check missing values.

df.isnull().sum()

# Check dataset
df.info()
df.describe()

"""# Data Cleaning"""

# Remove missing values

df = df.dropna()

df = df.drop_duplicates()

# Convert date column

df['tool_name'].nunique()

"""# Basic Dataset Understanding"""

# Check dataset size.

df.shape

# Check all columns.

df.columns

# See distribution of AI companies.

df['company'].value_counts()

# See tool categories.

df['category_canonical'].value_counts()

"""# Exploratory Data Analysis (EDA)

## 1. Top Companies Building AI Tools
"""

df['company'].value_counts().head(10)

# Visualization:

df['company'].value_counts().head(10).plot(kind='bar')
plt.title("Top Companies Creating AI Tools")
plt.show()

"""Insight example: Which company produces the most AI tools.

### AI Tool Categories Distribution
"""

df['category_canonical'].value_counts()

# Visualization:

df['category_canonical'].value_counts().plot(kind='bar')
plt.title("Distribution of AI Tool Categories")
plt.show()

"""### AI Tool Modalities"""

df[['mod_text','mod_image','mod_video','mod_audio','mod_code']].sum()

# Visualization:

df[['mod_text','mod_image','mod_video','mod_audio','mod_code']].sum().plot(kind='bar')
plt.title("AI Tool Modalities")
plt.show()

"""### 4. Open Source vs Closed Source"""

df['open_source'].value_counts()

# Visualization:

df['open_source'].value_counts().plot(kind='bar')
plt.title("Open Source vs Proprietary AI Tools")
plt.show()

"""Insight: Compare open-source ecosystem vs private tools.

### 6. AI Tool Release Trends
"""

# Check release year distribution.

df['release_year'].value_counts().sort_index()

# Visualization:

df['release_year'].value_counts().sort_index().plot(kind='line')
plt.title("AI Tool Release Trend Over Time")
plt.show()

"""Insight: AI boom after 2022–2023.

# Advanced Analysis

### 1. Multimodal AI Tools
"""

# Check tools supporting multiple modalities.

df[df['mod_multimodal']==1]['tool_name']

# Count:

df['mod_multimodal'].sum()

"""Insight: Growth of multimodal AI systems.

### 2. Average Modalities per Tool
"""

df['modality_count'].mean()

"""Insight: Shows how advanced AI tools are becoming.

### 3. AI Tool Category vs API Availability
"""

pd.crosstab(df['category_canonical'], df['api_available'])

"""Insight: Which categories provide APIs most.

# Export Clean Dataset
"""

# Save processed data.

df.to_csv("clean_ai_tools_dataset.csv", index=False)
